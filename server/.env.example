# Server
PORT=3001
NODE_ENV=development

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=whatsapp_bot
MYSQL_PASSWORD=botpass123
MYSQL_DATABASE=whatsapp_holiday_bot

# JWT
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRES_IN=7d

# Admin
ADMIN_PHONE=+972501234567
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# WhatsApp
WA_RATE_LIMIT=30
WA_DELAY_MIN=3000
WA_DELAY_MAX=8000
WA_MAX_RETRIES=3

# Auto-Reply
AUTO_REPLY_ENABLED=true
AUTO_REPLY_COOLDOWN_HOURS=24
AUTO_REPLY_TIMEOUT_MINUTES=240
AUTO_REPLY_WINDOW_START=07:00
AUTO_REPLY_WINDOW_END=22:00

# Canva Connect API (fallback)
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_REDIRECT_URI=http://localhost:3001/api/canva/auth/callback

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Timezone
TZ=Asia/Jerusalem
